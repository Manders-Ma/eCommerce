## PostgreSQL template placeholders - replace the ${...} tokens with real values or create a
## runtime env.properties that defines these variables.
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}
DB_NAME=${DB_NAME}
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}

## Gateway-internal JWT signing secret (must match Gateway)
GATEWAY_INTERNAL_JWT_SECRET=${GATEWAY_INTERNAL_JWT_SECRET}