## PostgreSQL template placeholders - replace the ${...} tokens with real values or create a
## runtime env.properties that defines these variables.
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}
DB_NAME=${DB_NAME}
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}

## LINE Pay credentials
LINEPAY_CHANNEL_ID=${LINEPAY_CHANNEL_ID}
LINEPAY_CHANNEL_SECRET=${LINEPAY_CHANNEL_SECRET}