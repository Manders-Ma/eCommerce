# 複製此檔為 .env 並填入真實值。.env 已被 .gitignore 排除，不會 commit。
#   PowerShell: Copy-Item .env.example .env
#   bash:       cp .env.example .env

# PostgreSQL
DB_HOST=REPLACE_ME
DB_PORT=REPLACE_ME
DB_NAME=REPLACE_ME
DB_USERNAME=REPLACE_ME
DB_PASSWORD=REPLACE_ME

# Gateway 簽發內部 JWT 用的密鑰，三個服務須一致（>= 32 bytes）
# 產生：openssl rand -base64 32
GATEWAY_INTERNAL_JWT_SECRET=REPLACE_ME

# LINE Pay sandbox
LINEPAY_CHANNEL_ID=REPLACE_ME
LINEPAY_CHANNEL_SECRET=REPLACE_ME
